{% extends 'base.html.twig' %}

{# On calcule l'URL absolue de l'image ici, accessible dans tous les blocs #}
{% set articleImage = vich_uploader_asset(article, 'imageFile') %}
{% set articleImageAbsolute = articleImage ? app.request.schemeAndHttpHost ~ articleImage : app.request.schemeAndHttpHost ~ asset('images/logo.png') %}

{# Titre de l'onglet navigateur #}
{% block title %}{{ article.titre }} — Maison Vintage{% endblock %}

{# Meta description : on tronque la description a 160 caracteres max pour Google #}
{% block meta_description %}
    <meta name="description" content="{{ article.description ? article.description|striptags|slice(0, 160) : 'Découvrez ' ~ article.titre ~ ' sur Maison Vintage, sélection unique de meubles et objets vintage en Bretagne.' }}">
{% endblock %}

{# Balises Open Graph specifiques a la fiche produit #}
{% block og_tags %}
    <meta property="og:type" content="product">
    <meta property="og:site_name" content="Maison Vintage">
    <meta property="og:title" content="{{ article.titre }} — Maison Vintage">
    <meta property="og:description" content="{{ article.description ? article.description|striptags|slice(0, 200) : 'Découvrez ' ~ article.titre ~ ' sur Maison Vintage.' }}">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:image" content="{{ articleImageAbsolute }}">
    <meta property="og:locale" content="fr_FR">
    {% if article.prix is not null %}
        <meta property="product:price:amount" content="{{ article.prix }}">
        <meta property="product:price:currency" content="EUR">
    {% endif %}
{% endblock %}

{% block body %}
    {# Schema JSON-LD : permet a Google d'afficher le prix et la disponibilite dans ses resultats #}
    <script type="application/ld+json">
        {
            "@context": "https://schema.org/",
            "@type": "Product",
            "name": {{ article.titre|json_encode|raw }},
        "description": {{ (article.description ? article.description|striptags : '')|json_encode|raw }},
        "image": {{ articleImageAbsolute|json_encode|raw }},
        "brand": {
            "@type": "Brand",
            "name": "Maison Vintage"
        },
        "offers": {
            "@type": "Offer",
            "url": {{ app.request.uri|json_encode|raw }},
            "priceCurrency": "EUR",
            "price": {{ article.prix is not null ? article.prix : '0' }},
            "availability": "{% if article.quantity is defined and article.quantity > 0 %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
            "seller": {
                "@type": "Organization",
                "name": "Maison Vintage"
            }
        }
    }
    </script>

    {# Lightbox : overlay plein ecran avec navigation entre les photos #}
    <div id="mv-lightbox"
         style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.92);z-index:9999;align-items:center;justify-content:center;touch-action:pan-y;">

        {# Bouton fermer #}
        <button id="mv-lightbox-close"
                style="-webkit-appearance:none;appearance:none;position:absolute;top:1rem;right:1rem;background:none;border:none;color:#fff;font-size:2rem;cursor:pointer;z-index:10000;padding:.5rem;touch-action:manipulation;">✕</button>

        {# Fleche precedente dans la lightbox #}
        <button id="mv-lightbox-prev"
                style="-webkit-appearance:none;appearance:none;position:absolute;left:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);border-radius:50%;width:3rem;height:3rem;font-size:1.5rem;color:#fff;cursor:pointer;z-index:10000;touch-action:manipulation;line-height:1;">
            ‹
        </button>

        {# Image affichee dans la lightbox #}
        <img id="mv-lightbox-img"
             src=""
             alt=""
             style="max-width:90vw;max-height:88vh;object-fit:contain;touch-action:pan-y;">

        {# Fleche suivante dans la lightbox #}
        <button id="mv-lightbox-next"
                style="-webkit-appearance:none;appearance:none;position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);border-radius:50%;width:3rem;height:3rem;font-size:1.5rem;color:#fff;cursor:pointer;z-index:10000;touch-action:manipulation;line-height:1;">
            ›
        </button>

        {# Compteur ex: "3 / 11" #}
        <div id="mv-lightbox-counter"
             style="position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.6);font-size:.85rem;">
        </div>
    </div>

    <section class="container" style="max-width:1100px;margin:2rem auto;padding:0 1rem;">
        {# Fil d'Ariane (breadcrumb) pour la navigation #}
        <nav style="margin-bottom:1rem;font-size:.95rem;">
            <a href="{{ path('home') ?? '/' }}">Accueil</a>
            &nbsp;›&nbsp;
            <a href="{{ path('categorie_show', {slug: article.categorie.slug}) }}">{{ article.categorie.nom }}</a>
            &nbsp;›&nbsp;
            <span>{{ article.titre }}</span>
        </nav>

        {# Détermine la source de l'image principale : image Vich OU première image de galerie OU placeholder #}
        {% set mainSrc = vich_uploader_asset(article, 'imageFile')
            ?? (article.images|length > 0 ? vich_uploader_asset(article.images|first, 'file') : asset('images/placeholder.png')) %}

        {# Grille responsive : image à gauche, infos à droite #}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

            {# Bloc de gauche : image principale et miniatures #}
            <div>
                {# Image principale cliquable pour ouvrir la lightbox #}
                <div id="product-main-wrap"
                     style="width:100%;border:1px solid #eee;border-radius:8px;background:#fff;overflow:visible;cursor:zoom-in;">
                    <img id="product-main"
                         src="{{ mainSrc }}"
                         alt="{{ article.titre }}"
                         style="width:100%;height:auto;display:block;max-height:520px;object-fit:contain;border-radius:8px;"
                         loading="eager">
                </div>

                {# Indication tactile pour mobile #}
                <p style="font-size:.75rem;color:#999;text-align:center;margin-top:.4rem;">
                    Appuyez sur l'image pour agrandir
                </p>

                {# Construction du tableau de miniatures (image principale + galerie) #}
                {% set thumbs = [] %}
                {% if vich_uploader_asset(article, 'imageFile') %}
                    {% set thumbs = thumbs|merge([ vich_uploader_asset(article, 'imageFile') ]) %}
                {% endif %}
                {% for img in article.images %}
                    {% set thumbs = thumbs|merge([ vich_uploader_asset(img, 'file') ]) %}
                {% endfor %}

                {# Affichage des miniatures cliquables #}
                {% if thumbs|length > 0 %}
                    <div class="thumbs" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;">
                        {% for src in thumbs %}
                            {% if src %}
                                <button class="thumb-btn"
                                        type="button"
                                        data-src="{{ src }}"
                                        data-index="{{ loop.index0 }}"
                                        style="-webkit-appearance:none;appearance:none;border:1px solid #e5e5e5;border-radius:6px;background:#fff;padding:0;cursor:pointer;touch-action:manipulation;">
                                    <img src="{{ src }}"
                                         alt="Aperçu {{ loop.index }}"
                                         style="width:86px;height:86px;object-fit:cover;display:block;border-radius:6px;"
                                         loading="lazy">
                                </button>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Bloc de droite : informations produit #}
            <div>
                <h1 style="margin:.25rem 0 1rem 0;">{{ article.titre }}</h1>

                {# Affichage conditionnel du prix #}
                {% if article.prix is not null %}
                    <div style="font-size:1.5rem;font-weight:700;margin-bottom:1rem;">
                        {{ article.prix|number_format(2, ',', ' ') }} €
                    </div>
                {% endif %}

                {# Affichage de la quantité disponible #}
                {% if article.quantity is not null %}
                    <div style="margin-bottom:.75rem;color:#444;">
                        Quantité disponible : {{ article.quantity }}
                    </div>
                {% endif %}

                {# Dimensions et poids du produit (affichage conditionnel) #}
                <div style="margin:1rem 0;color:#555;line-height:1.5;">
                    {% if article.weightKg %}
                        <div>Poids : {{ (article.weightKg + 0)|number_format(3, ',', ' ') }} kg</div>
                    {% endif %}
                    {% if article.lengthCm %}
                        <div>Longueur : {{ (article.lengthCm + 0)|number_format(1, ',', ' ') }} cm</div>
                    {% endif %}
                    {% if article.widthCm %}
                        <div>Largeur : {{ (article.widthCm + 0)|number_format(1, ',', ' ') }} cm</div>
                    {% endif %}
                    {% if article.heightCm %}
                        <div>Hauteur : {{ (article.heightCm + 0)|number_format(1, ',', ' ') }} cm</div>
                    {% endif %}
                </div>

                {# Description du produit avec conversion des retours à la ligne #}
                {% if article.description %}
                    <div style="margin:1rem 0 1.5rem 0;line-height:1.6;">
                        {{ article.description|nl2br }}
                    </div>
                {% endif %}

                {# Formulaire d'ajout au panier (uniquement si stock disponible) #}
                {% if article.quantity is defined and article.quantity > 0 %}
                    <form action="{{ path('cart_add', {id: article.id}) }}" method="post" style="margin:1rem 0 1.5rem 0;">
                        {# Token CSRF pour sécuriser la soumission du formulaire #}
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ article.id) }}">

                        {# Sélecteur de quantité (si plus d'un exemplaire disponible) #}
                        {% if article.quantity > 1 %}
                            <label for="qty" style="display:inline-block;margin-right:.5rem;">Quantité</label>
                            <input id="qty" name="qty" type="number" value="1" min="1" max="{{ article.quantity }}"
                                   style="width:90px;padding:.4rem;border:1px solid #ccc;border-radius:6px;margin-right:.5rem;">
                        {% else %}
                            <input type="hidden" name="qty" value="1">
                        {% endif %}

                        <button type="submit"
                                style="-webkit-appearance:none;appearance:none;padding:.6rem 1rem;border:1px solid #222;border-radius:8px;background:#222;color:#fff;cursor:pointer;touch-action:manipulation;">
                            Ajouter au panier
                        </button>
                    </form>
                {% else %}
                    {# Message de rupture de stock #}
                    <div style="margin:1rem 0 1.5rem 0;color:#a00;font-weight:600;">
                        Rupture de stock
                    </div>
                {% endif %}

                <a href="{{ path('categorie_show', {slug: article.categorie.slug}) }}"
                   style="display:inline-block;padding:.6rem 1rem;border:1px solid #222;border-radius:8px;text-decoration:none;">
                    ← Retour à {{ article.categorie.nom }}
                </a>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const mainImg = document.getElementById('product-main');
            const mainWrap = document.getElementById('product-main-wrap');
            const lightbox = document.getElementById('mv-lightbox');
            const lightboxImg = document.getElementById('mv-lightbox-img');
            const lightboxClose = document.getElementById('mv-lightbox-close');
            const lightboxPrev = document.getElementById('mv-lightbox-prev');
            const lightboxNext = document.getElementById('mv-lightbox-next');
            const lightboxCounter = document.getElementById('mv-lightbox-counter');

            // Tableau de toutes les sources construit depuis les miniatures du DOM
            const thumbBtns = Array.from(document.querySelectorAll('.thumb-btn'));
            const srcs = thumbBtns.map(function (btn) { return btn.getAttribute('data-src'); });

            // Index de la photo actuellement affichee dans la lightbox
            let currentIndex = 0;

            // On masque les fleches s'il n'y a qu'une seule image
            if (srcs.length <= 1) {
                lightboxPrev.style.display = 'none';
                lightboxNext.style.display = 'none';
                lightboxCounter.style.display = 'none';
            }

            // Ouvre la lightbox sur la photo a l'index donne
            function openLightbox(index) {
                currentIndex = index;
                lightboxImg.src = srcs[currentIndex];
                lightbox.style.display = 'flex';
                document.body.style.overflow = 'hidden';
                updateCounter();
            }

            // Ferme la lightbox
            function closeLightbox() {
                lightbox.style.display = 'none';
                document.body.style.overflow = '';
            }

            // Navigue vers l'index donne avec boucle circulaire
            function goTo(index) {
                if (index < 0) index = srcs.length - 1;
                if (index >= srcs.length) index = 0;
                currentIndex = index;

                // Fondu rapide pour eviter le flash entre les images
                lightboxImg.style.opacity = '0.2';
                const img = new Image();
                img.onload = function () {
                    lightboxImg.src = srcs[currentIndex];
                    lightboxImg.style.opacity = '1';
                };
                img.src = srcs[currentIndex];

                updateCounter();
            }

            // Met a jour le compteur "2 / 11"
            function updateCounter() {
                lightboxCounter.textContent = (currentIndex + 1) + ' / ' + srcs.length;
            }

            // Clic sur l'image principale -> ouvre la lightbox sur la photo 0
            if (mainWrap) {
                mainWrap.addEventListener('click', function () {
                    openLightbox(0);
                });
            }

            // Clic sur une miniature -> ouvre la lightbox sur la photo correspondante
            thumbBtns.forEach(function (btn, i) {
                btn.addEventListener('click', function () {
                    openLightbox(i);
                });
            });

            // Fleche precedente
            lightboxPrev.addEventListener('click', function (e) {
                e.stopPropagation();
                goTo(currentIndex - 1);
            });

            // Fleche suivante
            lightboxNext.addEventListener('click', function (e) {
                e.stopPropagation();
                goTo(currentIndex + 1);
            });

            // Fermeture via le bouton X
            lightboxClose.addEventListener('click', closeLightbox);

            // Fermeture en cliquant sur le fond noir
            lightbox.addEventListener('click', function (e) {
                if (e.target === lightbox) closeLightbox();
            });

            // Navigation au clavier : fleches gauche/droite et Echap
            document.addEventListener('keydown', function (e) {
                if (lightbox.style.display === 'none') return;
                if (e.key === 'ArrowLeft')  goTo(currentIndex - 1);
                if (e.key === 'ArrowRight') goTo(currentIndex + 1);
                if (e.key === 'Escape')     closeLightbox();
            });

            // Swipe tactile dans la lightbox
            let touchStartX = 0;
            let touchStartY = 0;

            lightbox.addEventListener('touchstart', function (e) {
                touchStartX = e.changedTouches[0].clientX;
                touchStartY = e.changedTouches[0].clientY;
            }, { passive: true });

            lightbox.addEventListener('touchend', function (e) {
                const deltaX = e.changedTouches[0].clientX - touchStartX;
                const deltaY = e.changedTouches[0].clientY - touchStartY;

                // Swipe horizontal uniquement (evite les faux positifs au scroll)
                if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > Math.abs(deltaY)) {
                    if (deltaX < 0) {
                        goTo(currentIndex + 1); // swipe gauche = suivant
                    } else {
                        goTo(currentIndex - 1); // swipe droite = precedent
                    }
                }
            }, { passive: true });
        });
    </script>
{% endblock %}
