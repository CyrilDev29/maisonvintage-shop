{# templates/invoice/invoice.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Facture {{ order.reference }}</title>
    <style>
        @page { margin: 40px 50px; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', Arial, Helvetica, sans-serif;
            font-size: 11px;
            color: #262626;
            line-height: 1.5;
            background: #ffffff;
        }

        /* Header */
        .header {
            display: table;
            width: 100%;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #EAE4DB;
        }
        .header-left {
            display: table-cell;
            width: 50%;
            vertical-align: middle;
            text-align: center;
            padding-left: 40px;
        }
        .header-right {
            display: table-cell;
            width: 50%;
            text-align: right;
            vertical-align: middle;
        }
        .logo-text {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 24px;
            font-weight: 600;
            color: #0E0E0E;
            letter-spacing: 0.15em;
        }
        .invoice-number {
            border: 2px solid #646F67;
            padding: 10px 20px;
            display: inline-block;
            font-size: 13px;
            font-weight: bold;
            color: #0E0E0E;
        }

        /* Date line */
        .date-line {
            border-top: 1px solid #EAE4DB;
            border-bottom: 1px solid #EAE4DB;
            padding: 10px 0;
            margin-bottom: 25px;
            font-size: 11px;
            color: #262626;
        }

        /* Addresses */
        .addresses {
            display: table;
            width: 100%;
            margin-bottom: 25px;
        }
        .address-box {
            display: table-cell;
            width: 48%;
            border: 1px solid #EAE4DB;
            padding: 15px;
            vertical-align: top;
            background: #F6F3EF;
        }
        .address-box:first-child {
            margin-right: 4%;
        }
        .address-box h3 {
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 10px;
            color: #0E0E0E;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .address-box p {
            font-size: 10px;
            line-height: 1.6;
            color: #262626;
        }

        /* Reference line */
        .reference-line {
            margin-bottom: 20px;
            font-size: 11px;
            font-weight: bold;
            color: #0E0E0E;
        }

        /* Table */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        thead {
            background: #F6F3EF;
            border-bottom: 2px solid #646F67;
        }
        th {
            padding: 10px 12px;
            text-align: left;
            font-size: 10px;
            font-weight: 700;
            color: #0E0E0E;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        th.center {
            text-align: center;
        }
        th.right {
            text-align: right;
        }
        td {
            padding: 10px 12px;
            font-size: 10px;
            border-left: 1px solid #EAE4DB;
            border-right: 1px solid #EAE4DB;
            color: #262626;
        }
        td.center {
            text-align: center;
        }
        td.right {
            text-align: right;
        }
        tbody tr:last-child td {
            border-bottom: 1px solid #EAE4DB;
        }

        /* Notes */
        .notes {
            font-size: 9px;
            margin-bottom: 15px;
            line-height: 1.5;
            color: #787878;
            font-style: italic;
        }

        /* Totals */
        .totals-table {
            width: 350px;
            float: right;
            border-collapse: collapse;
        }
        .totals-table td {
            border: 1px solid #EAE4DB;
            padding: 8px 12px;
            font-size: 11px;
        }
        .totals-table td.label {
            font-weight: 600;
            text-align: left;
            background: #F6F3EF;
            color: #262626;
        }
        .totals-table td.value {
            text-align: right;
            font-weight: 700;
            color: #0E0E0E;
        }
        .totals-table tr.final td {
            background: #646F67;
            color: #ffffff;
            font-size: 12px;
            font-weight: 700;
        }

        /* Clear float */
        .clear {
            clear: both;
        }

        /* Shipping info */
        .shipping-info {
            margin-top: 25px;
            border: 1px solid #EAE4DB;
            padding: 15px;
            background: #F6F3EF;
        }
        .shipping-info h3 {
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 8px;
            color: #0E0E0E;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .shipping-info p {
            font-size: 10px;
            line-height: 1.6;
            color: #262626;
        }

        /* Footer */
        footer {
            margin-top: 30px;
            padding-top: 15px;
            border-top: 2px solid #EAE4DB;
            font-size: 9px;
            line-height: 1.6;
            color: #787878;
        }
        footer p {
            margin: 3px 0;
        }
        footer strong {
            color: #0E0E0E;
        }

        /* Ribbon for seller copy */
        .ribbon {
            position: fixed;
            top: 50px;
            right: -70px;
            transform: rotate(45deg);
            padding: 8px 80px;
            background: #F6F3EF;
            border: 1px solid #646F67;
            color: #0E0E0E;
            text-transform: uppercase;
            font-size: 10px;
            font-weight: bold;
            letter-spacing: 0.1em;
        }
    </style>
</head>
<body>

{% if isSellerCopy %}
    <div class="ribbon">Copie vendeur</div>
{% endif %}

<!-- Header -->
<div class="header">
    <div class="header-left">
        <div class="logo-text">MAISON VINTAGE</div>
    </div>
    <div class="header-right">
        <div class="invoice-number">Facture n° {{ order.reference }}</div>
    </div>
</div>

<!-- Date line -->
<div class="date-line">
    Date : {{ order.createdAt|date('d/m/Y') }}
</div>

<!-- Addresses -->
<div class="addresses">
    <!-- Billing address -->
    <div class="address-box">
        <h3>Adresse de facturation</h3>
        {% set bill = order.billingSnapshot ?? order.shippingSnapshot ?? null %}
        {% if bill %}
            <p>
                {{ bill.fullName }}<br>
                {{ bill.line1 }}<br>
                {% if bill.line2 %}{{ bill.line2 }}<br>{% endif %}
                {{ bill.postalCode }} {{ bill.city }}<br>
                {% if bill.phone %}{{ bill.phone }}{% endif %}
            </p>
        {% else %}
            <p>
                {{ order.prenom }} {{ order.nom }}<br>
                {{ order.rue }}<br>
                {{ order.codePostal }} {{ order.ville }}
            </p>
        {% endif %}
    </div>

    <!-- Shipping address -->
    <div class="address-box">
        <h3>Adresse de livraison</h3>
        {% set ship = order.shippingSnapshot %}
        {% if ship %}
            <p>
                {{ ship.fullName }}<br>
                {{ ship.line1 }}<br>
                {% if ship.line2 %}{{ ship.line2 }}<br>{% endif %}
                {{ ship.postalCode }} {{ ship.city }}<br>
                {% if ship.phone %}{{ ship.phone }}{% endif %}
            </p>
        {% else %}
            <p>
                {{ order.prenom }} {{ order.nom }}<br>
                {{ order.rue }}<br>
                {{ order.codePostal }} {{ order.ville }}
            </p>
        {% endif %}
    </div>
</div>

<!-- Reference -->
<div class="reference-line">
    Référence : {{ order.reference }}
</div>

<!-- Items table -->
<table>
    <thead>
    <tr>
        <th>Désignation</th>
        <th class="center">Qte</th>
        <th class="center">TVA</th>
        <th class="right">Prix unitaire</th>
        <th class="right">Prix Total</th>
    </tr>
    </thead>
    <tbody>
    {% for line in order.items %}
        {% set unit = (line.unitPrice|replace({',':'.'})) + 0 %}
        {% set total = (line.getLineTotal()|replace({',':'.'})) + 0 %}
        <tr>
            <td>{{ line.productName }}</td>
            <td class="center">{{ line.quantity }}</td>
            <td class="center">-</td>
            <td class="right">{{ unit|number_format(2, ',', ' ') }}</td>
            <td class="right">{{ total|number_format(2, ',', ' ') }} €</td>
        </tr>
    {% endfor %}

    <!-- Shipping line if applicable -->
    {% set total_port = (order.shippingAmountCents is defined ? (order.shippingAmountCents / 100) : 0) + 0 %}
    {% if total_port > 0 %}
        <tr>
            <td>Frais de port</td>
            <td class="center">1</td>
            <td class="center">-</td>
            <td class="right">{{ total_port|number_format(2, ',', ' ') }}</td>
            <td class="right">{{ total_port|number_format(2, ',', ' ') }} €</td>
        </tr>
    {% endif %}
    </tbody>
</table>

<!-- Notes -->
<div class="notes">
    * TVA non applicable, art. 293 B du CGI (Franchise en base de TVA)
</div>

<!-- Totals -->
{% set total_articles = (order.total|default(0)) + 0 %}
{% set total_ttc = total_articles + total_port %}

<table class="totals-table">
    <tr>
        <td class="label">Total HT</td>
        <td class="value">{{ total_ttc|number_format(2, ',', ' ') }} €</td>
    </tr>
    <tr>
        <td class="label">Total TVA</td>
        <td class="value">0,00 €</td>
    </tr>
    <tr class="final">
        <td class="label">Total TTC</td>
        <td class="value">{{ total_ttc|number_format(2, ',', ' ') }} €</td>
    </tr>
</table>

<div class="clear"></div>

<!-- Shipping info if different carriers -->
{% if order.shippingCarrier or order.shippingMethod %}
    <div class="shipping-info">
        <h3>Informations de transport</h3>
        <p>
            {% if order.shippingCarrier %}<strong>Transporteur :</strong> {{ order.shippingCarrier }}{% endif %}
            {% if order.shippingMethod %} - {{ order.shippingMethod }}{% endif %}
            {% if order.shippingRelayId %}<br><strong>Point relais :</strong> {{ order.shippingRelayId }}{% endif %}
        </p>
    </div>
{% endif %}

<!-- Footer -->
<footer>
    <p><strong>Conditions de paiement :</strong> Paiement comptant</p>
    <p><strong>Pénalités de retard :</strong> Taux légal en vigueur (3 fois le taux d'intérêt légal)</p>
    <p><strong>Indemnité forfaitaire pour frais de recouvrement :</strong> 40 euros</p>
    <p><strong>Escompte :</strong> Aucun escompte pour paiement anticipé</p>
    <p style="margin-top: 10px;">
        <strong>Maison Vintage - EI</strong> - 95 Kerizac, 29870 Landéda<br>
        SIRET 752 102 897 00036 - TVA FR45752102897 - RCS Brest 752 102 897<br>
        Facture émise le {{ 'now'|date('d/m/Y à H:i') }}
    </p>
</footer>

</body>
</html>

