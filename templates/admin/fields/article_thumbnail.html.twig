{# templates/admin/fields/article_thumbnail.html.twig #}
{% set mainSrc = vich_uploader_asset(entity.instance, 'imageFile')
    ?? (attribute(entity.instance, 'images') is defined and entity.instance.images|length > 0
    ? vich_uploader_asset(entity.instance.images|first, 'file')
    : null)
%}

{% if not mainSrc %}
    {# autres fallbacks courants #}
    {% if attribute(entity.instance, 'imageUrl') is defined and entity.instance.imageUrl %}
        {% set mainSrc = entity.instance.imageUrl %}
    {% elseif attribute(entity.instance, 'imagePath') is defined and entity.instance.imagePath %}
        {% set mainSrc = entity.instance.imagePath %}
    {% elseif attribute(entity.instance, 'imageName') is defined and entity.instance.imageName %}
        {% set mainSrc = '/uploads/articles/' ~ entity.instance.imageName %}
    {% elseif attribute(entity.instance, 'image') is defined and entity.instance.image %}
        {% set _img = entity.instance.image %}
        {% set mainSrc = (_img starts with 'http' or _img starts with '/') ? _img : '/uploads/articles/' ~ _img %}
    {% endif %}
{% endif %}

{% set alt = (attribute(entity.instance, 'titre') is defined ? entity.instance.titre : 'Article') %}

<div style="display:flex;align-items:center;gap:.5rem;">
    {% if mainSrc %}
        <img src="{{ mainSrc }}" alt="{{ alt }}"
             style="width:52px;height:52px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb;">
    {% else %}
        <span class="badge bg-secondary">—</span>
    {% endif %}
</div>
