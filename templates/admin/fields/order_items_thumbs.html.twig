{# templates/admin/fields/order_items_thumbs.html.twig #}
{% set order = entity.instance %}
{% if order and order.items|length > 0 %}
    <div style="display:flex;gap:6px;flex-wrap:wrap;max-width:260px">
        {% for it in order.items|slice(0,4) %}
            {% set src = it.productImage ?? null %}
            {% if src %}
                {% set url = (src starts with 'http') ? src : asset(src) %}
                <img src="{{ url }}" alt="" style="width:38px;height:38px;object-fit:cover;border-radius:4px;border:1px solid rgba(255,255,255,.25)">
            {% else %}
                <span class="badge bg-secondary">—</span>
            {% endif %}
        {% endfor %}
        {% if order.items|length > 4 %}
            <span class="badge bg-dark">+{{ order.items|length - 4 }}</span>
        {% endif %}
    </div>
{% else %}
    <span class="badge bg-danger">Inaccessible</span>
{% endif %}
