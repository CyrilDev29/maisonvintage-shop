{# templates/registration/confirmation_email.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmez votre e-mail</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            background: #f9f6f1;
            padding: 40px 20px;
            color: #262626;
            line-height: 1.6;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background: #ffffff;
            overflow: hidden;
        }
        .header {
            background: #ffffff;
            padding: 40px 30px 30px;
            text-align: center;
            border-bottom: 1px solid #EAE4DB;
        }
        .logo-text {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 28px;
            font-weight: 600;
            color: #0E0E0E;
            letter-spacing: 0.1em;
            margin-bottom: 8px;
        }
        .subtitle {
            font-size: 13px;
            color: #787878;
            text-transform: uppercase;
            letter-spacing: 0.15em;
        }
        .content {
            padding: 40px 30px;
            background: #ffffff;
            text-align: center;
        }
        .greeting {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 24px;
            margin-bottom: 20px;
            color: #0E0E0E;
        }
        .button {
            display: inline-block;
            background: #646F67;
            color: #ffffff !important;
            text-decoration: none;
            padding: 16px 40px;
            font-weight: 600;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin: 25px 0;
            transition: background 0.2s;
        }
        .button:hover { background: #4f5952; }
        .info-box {
            background: #F6F3EF;
            border-left: 3px solid #C28A32;
            padding: 15px;
            margin: 25px 0;
            text-align: left;
        }
        .info-box p {
            font-size: 13px;
            color: #262626;
            line-height: 1.6;
            margin: 0;
        }
        .footer {
            background: #F6F3EF;
            padding: 30px;
            text-align: center;
            font-size: 12px;
            color: #787878;
            border-top: 1px solid #EAE4DB;
        }
        .footer a {
            color: #646F67;
            text-decoration: none;
            margin: 0 8px;
        }
        .footer a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div class="email-container">

    <!-- Header -->
    <div class="header">
        <div class="logo-text">MAISON VINTAGE</div>
        <div class="subtitle">Bienvenue</div>
    </div>

    <!-- Content -->
    <div class="content">
        <p class="greeting">Bienvenue {{ user.email }} !</p>

        <p style="font-size: 14px; color: #787878; margin-bottom: 20px;">
            Merci pour votre inscription sur Maison Vintage,<br>
            votre boutique de meubles et objets vintage soigneusement chinés.
        </p>

        <p style="font-size: 14px; color: #262626; margin-bottom: 10px;">
            Pour activer votre compte et commencer vos achats,<br>
            veuillez confirmer votre adresse email :
        </p>

        <a href="{{ signedUrl }}" class="button">Confirmer mon e-mail</a>

        {% if expiresAtMessageKey is defined %}
            <div class="info-box">
                <p>
                    <strong>Important :</strong> {{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}.
                </p>
            </div>
        {% endif %}

        <p style="font-size: 13px; color: #787878; margin-top: 30px; padding: 15px; background: #F6F3EF;">
            Si vous n'avez pas créé de compte sur Maison Vintage, vous pouvez ignorer cet email.
        </p>

        <p style="margin-top: 35px; font-size: 14px; color: #787878;">
            À très bientôt,<br>
            <strong style="color: #262626;">L'équipe Maison Vintage</strong>
        </p>
    </div>

    <!-- Footer -->
    <div class="footer">
        <p style="margin-bottom: 12px; font-weight: 600; color: #262626;">&copy; {{ 'now'|date('Y') }} Maison Vintage</p>
        <p>
            <a href="{{ url('cgv') }}">CGV</a> •
            <a href="{{ url('mentions_legales') }}">Mentions légales</a> •
            <a href="{{ url('politique_confidentialite') }}">Confidentialité</a>
        </p>
        <p style="margin-top: 12px;">95 Kerizac, 29870 Landéda</p>
    </div>

</div>
</body>
</html>
