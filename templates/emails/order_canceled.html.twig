{# templates/emails/order_canceled.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Commande annulée</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            background: #f9f6f1;
            padding: 40px 20px;
            color: #262626;
            line-height: 1.6;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background: #ffffff;
            overflow: hidden;
        }
        .header {
            background: #ffffff;
            padding: 40px 30px 30px;
            text-align: center;
            border-bottom: 1px solid #EAE4DB;
        }
        .logo-text {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 28px;
            font-weight: 600;
            color: #0E0E0E;
            letter-spacing: 0.1em;
            margin-bottom: 8px;
        }
        .subtitle {
            font-size: 13px;
            color: #C24040;
            text-transform: uppercase;
            letter-spacing: 0.15em;
        }
        .content {
            padding: 40px 30px;
            background: #ffffff;
        }
        .greeting {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 22px;
            margin-bottom: 20px;
            color: #0E0E0E;
        }
        .badge {
            display: inline-block;
            padding: 8px 16px;
            border-radius: 0;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin: 5px 5px 5px 0;
        }
        .badge-canceled { background: #C24040; color: #ffffff; }
        .badge-refunded { background: #2F8F54; color: #ffffff; }
        .badge-warning { background: #C28A32; color: #ffffff; }
        .info-box {
            background: #F6F3EF;
            border-left: 3px solid #C24040;
            padding: 20px;
            margin: 20px 0;
        }
        .info-box h3 {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #C24040;
        }
        .info-box p {
            font-size: 13px;
            color: #262626;
            margin: 4px 0;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 25px 0;
        }
        th {
            background: #F6F3EF;
            padding: 12px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            color: #262626;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid #EAE4DB;
        }
        th.right { text-align: right; }
        td {
            padding: 15px 12px;
            border-bottom: 1px solid #EAE4DB;
            font-size: 14px;
            color: #262626;
        }
        td.right { text-align: right; }
        .total-row td {
            font-weight: 700;
            background: #F6F3EF;
        }
        .footer {
            background: #F6F3EF;
            padding: 30px;
            text-align: center;
            font-size: 12px;
            color: #787878;
            border-top: 1px solid #EAE4DB;
        }
        .footer a {
            color: #646F67;
            text-decoration: none;
            margin: 0 8px;
        }
        .footer a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div class="email-container">

    <!-- Header -->
    <div class="header">
        <div class="logo-text">MAISON VINTAGE</div>
        <div class="subtitle">Commande annulée</div>
    </div>

    <!-- Content -->
    <div class="content">
        <p class="greeting">Bonjour,</p>

        <!-- Status badges -->
        <div style="margin: 20px 0;">
            <span class="badge badge-canceled">ANNULÉE</span>
            {% if refundedNow or order.refundedAt %}
                <span class="badge badge-refunded">REMBOURSÉE</span>
            {% else %}
                <span class="badge badge-warning">REMBOURSEMENT EN COURS</span>
            {% endif %}
        </div>

        <p style="font-size: 14px; color: #787878; margin-bottom: 25px;">
            La commande <strong style="color: #262626;">{{ order.reference }}</strong> a été annulée.
        </p>

        <!-- Order details -->
        <div class="info-box">
            <h3>Informations de la commande</h3>
            <p><strong>Date de création :</strong> {{ order.createdAt|date('d/m/Y H:i') }}</p>
            <p><strong>Client :</strong> {{ order.prenom }} {{ order.nom }}</p>
            <p><strong>Email :</strong> {{ order.user.email }}</p>
            {% if order.telephone %}<p><strong>Téléphone :</strong> {{ order.telephone }}</p>{% endif %}
            <p><strong>Annulée le :</strong> {{ order.canceledAt ? order.canceledAt|date('d/m/Y H:i') : '—' }}</p>
        </div>

        <!-- Items table -->
        <h3 style="margin: 25px 0 15px; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 18px; color: #0E0E0E;">Articles de la commande</h3>
        <table>
            <thead>
            <tr>
                <th>Produit</th>
                <th class="right">Prix unitaire</th>
                <th class="right">Quantité</th>
                <th class="right">Sous-total</th>
            </tr>
            </thead>
            <tbody>
            {% for item in order.items %}
                {% set unit = (item.unitPrice|replace({',':'.'})) + 0 %}
                {% set qty = (item.quantity ?? 0) + 0 %}
                {% set sub = unit * qty %}
                <tr>
                    <td>{{ item.productName }}</td>
                    <td class="right">{{ unit|number_format(2, ',', ' ') }} €</td>
                    <td class="right">{{ qty }}</td>
                    <td class="right">{{ sub|number_format(2, ',', ' ') }} €</td>
                </tr>
            {% endfor %}
            {% set total_num = (order.total|replace({',':'.'})) + 0 %}
            <tr class="total-row">
                <td colspan="3" class="right">Total :</td>
                <td class="right">{{ total_num|number_format(2, ',', ' ') }} €</td>
            </tr>
            </tbody>
        </table>

        <!-- Delivery address -->
        <h3 style="margin: 25px 0 10px; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 18px; color: #0E0E0E;">Adresse de livraison</h3>
        <p style="font-size: 14px; color: #262626; line-height: 1.6; background: #F6F3EF; padding: 15px; border-left: 3px solid #EAE4DB;">
            {{ order.prenom }} {{ order.nom }}<br>
            {{ order.rue }}<br>
            {{ order.codePostal }} {{ order.ville }}<br>
            {{ order.pays }}
        </p>

        <p style="margin-top: 35px; font-size: 14px; color: #787878; text-align: center;">
            Si vous avez des questions concernant cette annulation, n'hésitez pas à nous contacter.<br><br>
            <strong style="color: #262626;">L'équipe Maison Vintage</strong>
        </p>
    </div>

    <!-- Footer -->
    <div class="footer">
        <p style="margin-bottom: 12px; font-weight: 600; color: #262626;">&copy; {{ 'now'|date('Y') }} Maison Vintage</p>
        <p>
            <a href="{{ url('cgv') }}">CGV</a> •
            <a href="{{ url('mentions_legales') }}">Mentions légales</a> •
            <a href="{{ url('politique_confidentialite') }}">Confidentialité</a>
        </p>
        <p style="margin-top: 12px;">95 Kerizac, 29870 Landéda</p>
    </div>

</div>
</body>
</html>
